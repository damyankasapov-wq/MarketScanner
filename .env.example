# Copy this file to .env and fill in your values.
# .env is excluded from git — never commit real credentials.

FINNHUB_API_KEY=

# Feed source: "auto" (Finnhub WS, yfinance fallback) or "yfinance" (poll only).
# docker-compose sets this to yfinance because the Finnhub free tier does not
# stream US ETFs.
FEED_MODE=auto

EMAIL_SENDER=
EMAIL_PASSWORD=        # Gmail app password
EMAIL_RECIPIENT=

# Deployment target (used by scripts/deploy.sh)
OVM_HOST=openmediavault.local
OVM_USER=root

# PostgreSQL (defaults match docker-compose.yml)
DB_HOST=openmediavault.local
DB_PORT=5432
DB_NAME=marketscanner
DB_USER=ms
DB_PASSWORD=ms
